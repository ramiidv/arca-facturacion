{
  "name": "@ramiidv/arca-facturacion",
  "version": "2.0.0",
  "description": "SDK para Facturación Electrónica con ARCA (ex AFIP) - WSFE, WSFEX, CAEA, QR",
  "author": "ramiidv",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "llm.txt",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "afip",
    "arca",
    "factura-electronica",
    "facturacion",
    "wsfe",
    "wsfex",
    "wsaa",
    "argentina",
    "cae",
    "caea",
    "invoice",
    "factura",
    "mipyme",
    "fce",
    "soap",
    "tax",
    "electronic-invoice",
    "padron",
    "exportacion",
    "qr"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ramiidv/arca-facturacion.git"
  },
  "homepage": "https://arca-sdk.dev/",
  "bugs": {
    "url": "https://github.com/ramiidv/arca-facturacion/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@ramiidv/arca-common": "^0.1.0",
    "fast-xml-parser": "^5.5.9",
    "node-forge": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/node-forge": "^1.3.14",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
